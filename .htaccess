Options -Indexes

# ─── Security headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Empêcher l'affichage dans une iframe (clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"
    # Empêcher le MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Forcer HTTPS pendant 1 an (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Protection XSS sur les navigateurs anciens
    Header always set X-XSS-Protection "1; mode=block"
    # Politique de référent (ne pas leaker l'URL interne)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy : whitelist des sources autorisees
    # - script/style 'unsafe-inline' temporaire (a remplacer par des nonces plus tard)
    # - CDN whitelistes : fonts Google, Font Awesome, Chart.js
    # - api.qrserver.com pour le fallback de generation QR
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https://api.qrserver.com; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"

    # Permissions-Policy : desactiver les features browser non utilisees
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

    # Supprimer la signature du serveur
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ─── Routage MVC ─────────────────────────────────────────────────────────────
RewriteEngine On
RewriteBase /

# Ignorer les fichiers et dossiers existants (assets, images…)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rediriger tout vers index.php
RewriteRule ^(.*)$ index.php [QSA,L]
